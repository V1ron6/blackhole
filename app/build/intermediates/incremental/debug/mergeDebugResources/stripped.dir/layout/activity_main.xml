<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bh_background">

    <!-- Top bar: tab switcher + URL bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bh_surface"
        android:paddingHorizontal="8dp"
        android:paddingVertical="6dp">

        <LinearLayout
            android:id="@+id/tabIndicatorContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:background="@android:color/transparent"
            android:hint="@string/url_bar_hint"
            android:textColor="@color/bh_text"
            android:textColorHint="@color/bh_text_dim"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:maxLines="1" />

        <ImageButton
            android:id="@+id/btnNewTab"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="@string/new_tab"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnSettings"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Security settings"
            app:tint="@color/bh_text_dim" />
    </LinearLayout>

    <!-- WebView container - holds up to 2 WebViews, only active one visible -->
    <FrameLayout
        android:id="@+id/webViewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom nav bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bh_surface"
        android:paddingVertical="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="@string/go_back"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnForward"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="@string/go_forward"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnHome"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="@string/go_home"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnReload"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_popup_sync"
            android:contentDescription="@string/reload"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnJsToggle"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_edit"
            android:contentDescription="@string/js_toggle"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnRequestLog"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_recent_history"
            android:contentDescription="Request log"
            app:tint="@color/bh_text_dim" />

        <ImageButton
            android:id="@+id/btnClearSession"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="@string/clear_session"
            app:tint="@color/bh_danger" />
    </LinearLayout>
</LinearLayout>
