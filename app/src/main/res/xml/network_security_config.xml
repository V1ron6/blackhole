<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cleartext is permitted at the OS level so CTF Mode can load http://
         targets when the user enables it. The actual http:// vs https://
         enforcement happens in app code (SecureWebView.kt) based on the
         Strict/CTF toggle in Settings - this file only controls what the
         OS *allows*, not what Blackhole actually does by default. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
